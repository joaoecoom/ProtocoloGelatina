generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlanId {
  FRONT
  UPSELL_1
  DS1_UP1
  DS2_UP1
  DS3_UP1
  UPSELL_2
  DS1_UP2
  DS2_UP2
  DS3_UP2
}

/// Perfil da app; `id` = `auth.users.id` (Supabase Auth)
model User {
  id                    String         @id @db.Uuid
  email                 String         @unique
  name                  String
  plan                  PlanId         @default(FRONT)
  onboardingCompleted   Boolean        @default(false)
  age                   Int?
  heightCm              Float?
  weightKg              Float?
  goalWeightKg          Float?
  goal                  String?
  mainProblem           String?
  streak                Int            @default(0)
  lastGelatinaAt        DateTime?
  startWeightKg         Float?
  /// Quando a utilizadora fecha o guia de primeiros passos (null = ainda não viu).
  welcomeGuideDismissedAt DateTime?
  /// Acesso total a conteúdos / limites como plano máximo (uso interno).
  isSuperAdmin          Boolean        @default(false)
  /// Foto de perfil: URL pública (Supabase Storage, bucket `avatars`; requer SUPABASE_SERVICE_ROLE_KEY).
  avatarUrl             String?
  /// Horários das refeições para lembretes push no servidor (JSON: markManha, markAlmoco, … "HH:MM").
  mealReminderSchedule  Json?
  /// IANA, ex. Europe/Lisbon — usado pelo cron para “hoje” e hora local.
  reminderTimeZone      String?        @db.VarChar(80)
  /// Preferências de notificação persistidas (ex.: daily, progress, reactivation).
  notificationPrefs     Json?
  /// Planos de protocolo activos para push no servidor: [{ id, startedAt }].
  activeProtocolPlans   Json?
  /// Check-ins de plano por dia: chave `planId:YYYY-MM-DD` → true (espelho do localStorage).
  protocolPlanCheckins  Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  trackingDays          DailyTrack[]
  gelatinaLogs          GelatinaLog[]
  chatUsages            ChatUsage[]
  chatMessages          ChatMessage[]
  pushSubscriptions     PushSubscription[]
  pushReminderLogs      PushReminderLog[]
}

/// Subscrição Web Push (FCM/APNs via browser); uma por endpoint/dispositivo.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Evita reenviar o mesmo lembrete no mesmo dia (cron).
model PushReminderLog {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateYmd   String   @db.VarChar(10)
  kind      String   @db.VarChar(64)
  createdAt DateTime @default(now())

  @@unique([userId, dateYmd, kind])
  @@index([userId, dateYmd])
}

model DailyTrack {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  waterMl   Int      @default(0)
  /// Nota curta "como te sentes hoje" (check-in do dia).
  moodNote  String?  @db.VarChar(500)
  bloating  Int      @default(3)
  energy    Int      @default(3)
  hunger    Int      @default(3)
  sleep     Int      @default(3)
  /// Marcações por momento do dia (manhã, almoço, lanche, janta) — lembretes 3–4x/dia.
  markManha  Boolean  @default(false)
  markAlmoco Boolean  @default(false)
  markLanche Boolean  @default(false)
  markJanta  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, date])
}

model GelatinaLog {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model ChatUsage {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  text      String   @db.VarChar(4000)
  createdAt DateTime @default(now())
}

/// Eventos de funil do quiz para métricas agregadas (entrada, cliques, drop-off, checkout).
model QuizMetricEvent {
  id         String   @id @default(cuid())
  sessionId  String   @db.VarChar(80)
  eventType  String   @db.VarChar(64)
  step       Int?
  stepId     String?  @db.VarChar(80)
  questionId String?  @db.VarChar(80)
  optionId   String?  @db.VarChar(120)
  buttonId   String?  @db.VarChar(120)
  path       String?  @db.VarChar(200)
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([sessionId, createdAt])
  @@index([stepId, createdAt])
}

model Event {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String   @unique @map("event_id")
  eventName     String   @map("event_name")
  eventVersion  Int      @default(1) @map("event_version")
  timestamp     DateTime @default(now())
  sessionId     String?  @map("session_id")
  visitorId     String?  @map("visitor_id")
  anonymousId   String?  @map("anonymous_id")
  leadId        String?  @map("lead_id")
  userId        String?  @map("user_id")
  orderId       String?  @map("order_id")
  funnelId      String?  @map("funnel_id")
  stepId        String?  @map("step_id")
  pageType      String?  @map("page_type")
  utmSource     String?  @map("utm_source")
  utmMedium     String?  @map("utm_medium")
  utmCampaign   String?  @map("utm_campaign")
  utmContent    String?  @map("utm_content")
  utmTerm       String?  @map("utm_term")
  fbclid        String?
  gclid         String?
  ttclid        String?
  ip            String?
  country       String?
  device        String?
  browser       String?
  os            String?
  referrer      String?
  revenue       Decimal? @db.Decimal(14, 2)
  currency      String?
  schemaName    String   @default("core_event") @map("schema_name")
  schemaVersion Int      @default(1) @map("schema_version")
  metadataJson  Json     @default("{}") @map("metadata_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([eventName], map: "idx_events_event_name")
  @@index([timestamp], map: "idx_events_timestamp")
  @@index([sessionId], map: "idx_events_session_id")
  @@index([leadId], map: "idx_events_lead_id")
  @@index([orderId], map: "idx_events_order_id")
  @@index([funnelId, stepId], map: "idx_events_funnel_step")
  @@index([anonymousId], map: "idx_events_anonymous_id")
  @@index([visitorId], map: "idx_events_visitor_id")
  @@map("events")
}
