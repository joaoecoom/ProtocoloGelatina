# =============================================================================
# MODELO — copia para secrets.env e preenche. Lista gerada a partir do código.
# npm run env:sync  →  copia secrets.env para .env.local na raiz
# =============================================================================

# --- URLs públicas (site) ---
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=

# --- Supabase (browser + servidor) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (scripts opcionais: npm run supabase:auth-urls) ---
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_MANAGEMENT_API_TOKEN=
# SUPABASE_PROJECT_REF=

# --- Postgres / Prisma (schema.prisma) ---
DATABASE_URL=
DIRECT_URL=

# --- Stripe (checkout + webhook + seed) ---
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_DEV_MOCK_CHECKOUT=0

# Preços mensais (price_...) — opcional se usares npm run stripe:seed na mesma conta
STRIPE_PRICE_FRONT=
# STRIPE_PRICE_UPSELL_1=
# STRIPE_PRICE_DS1_UP1=
# STRIPE_PRICE_DS2_UP1=
# STRIPE_PRICE_DS3_UP1=
# STRIPE_PRICE_UPSELL_2=
# STRIPE_PRICE_DS1_UP2=
# STRIPE_PRICE_DS2_UP2=
# STRIPE_PRICE_DS3_UP2=

# Preços de entrada / intro (opcional; checkout pode usar price_data inline)
# STRIPE_PRICE_FRONT_INTRO=
# STRIPE_PRICE_UPSELL_1_INTRO=
# STRIPE_PRICE_DS1_UP1_INTRO=
# STRIPE_PRICE_DS2_UP1_INTRO=
# STRIPE_PRICE_DS3_UP1_INTRO=
# STRIPE_PRICE_UPSELL_2_INTRO=
# STRIPE_PRICE_DS1_UP2_INTRO=
# STRIPE_PRICE_DS2_UP2_INTRO=
# STRIPE_PRICE_DS3_UP2_INTRO=

# --- Stripe (cliente JS, se no futuro usares Stripe no browser) ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- OpenRouter / Jéssica (src/lib/openrouter-jessica.ts) ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# OPENROUTER_HTTP_REFERER=

# --- Web Push (src/lib/push/*, notification-settings-card) ---
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=

# --- Cron Vercel (src/app/api/cron/push-reminders/route.ts) ---
# CRON_SECRET=

# --- Quiz dashboard API (src/app/api/quizdashboard/access/route.ts) ---
# QUIZDASHBOARD_PASSWORD=

# --- Tracking / integrações (src/lib/tracking/integrations/config.ts) ---
